{
"compilerOptions": {
"target": "ES2020",
"module": "CommonJS",
"moduleResolution": "node",
"strict": true,
"esModuleInterop": true,
"skipLibCheck": true,
"types": ["node"],
"verbatimModuleSyntax": false,
"outDir": "dist"
},
"include": ["src/**/*.ts", "scripts/**/*.ts"],
"exclude": ["node_modules"]
}
